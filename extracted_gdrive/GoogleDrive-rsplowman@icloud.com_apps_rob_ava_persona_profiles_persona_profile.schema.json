{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NOIZYVOX Persona Profile",
  "type": "object",
  "required": [
    "persona_id",
    "owner_id",
    "display_name",
    "languages",
    "consent_level",
    "collaboration_rules"
  ],
  "properties": {
    "persona_id": {
      "type": "string",
      "minLength": 2,
      "description": "Unique AVA identifier; UUIDv4 recommended."
    },
    "owner_id": {
      "type": "string",
      "minLength": 2,
      "description": "Farm owner identifier."
    },
    "display_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 128
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "character_traits": {
      "type": "object",
      "additionalProperties": true
    },
    "voice_parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "consent_level": {
      "type": "string",
      "enum": [
        "private",
        "crew-only",
        "public"
      ]
    },
    "collaboration_rules": {
      "type": "object",
      "required": [
        "allowed_partners",
        "restricted_topics",
        "max_interaction_duration"
      ],
      "properties": {
        "allowed_partners": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "restricted_topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "max_interaction_duration": {
          "type": "integer",
          "minimum": 30,
          "maximum": 7200
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "approved",
        "rejected"
      ],
      "default": "candidate"
    },
    "review_log": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
