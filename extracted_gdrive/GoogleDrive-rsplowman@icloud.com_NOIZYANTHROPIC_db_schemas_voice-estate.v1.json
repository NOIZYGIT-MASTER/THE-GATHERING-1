{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noizy.ai/schemas/voice-estate.v1.json",
  "title": "Voice Estate v1.0 — NOIZY Creator Identity Registry",
  "description": "Immutable identity and governance record for a creator's voice sovereignty. Anchors all NCP agreements.",
  "type": "object",
  "required": [
    "voice_estate_id", "creator_id", "hvs_id", "estate_status",
    "acoustic_fingerprint", "primary_voiceprints", "governance_rules",
    "created_at", "updated_at"
  ],
  "properties": {
    "voice_estate_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this voice estate. Immutable after creation."
    },
    "creator_id": {
      "type": "string",
      "description": "Reference to creators.id in D1 registry."
    },
    "hvs_id": {
      "type": "string",
      "description": "Human Voice Sovereignty identifier. Issued at registration. Immutable."
    },
    "estate_status": {
      "type": "string",
      "enum": ["active", "inactive", "transferred", "probate_pending"],
      "description": "Current operational status of the voice estate."
    },
    "sovereignty_status": {
      "type": "string",
      "enum": ["claimed", "verified", "contested", "inactive"],
      "description": "Verification state of the creator's sovereignty claim."
    },
    "acoustic_fingerprint": {
      "type": "string",
      "description": "Hash of creator's primary voice biometric. Used for identity verification. Never exposed publicly (Never Clause NC-9)."
    },
    "primary_voiceprints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["voiceprint_id", "hash", "captured_at", "capture_method"],
        "properties": {
          "voiceprint_id": { "type": "string", "format": "uuid" },
          "hash": {
            "type": "string",
            "description": "Cryptographic hash of the voiceprint sample."
          },
          "captured_at": { "type": "string", "format": "date-time" },
          "capture_method": {
            "type": "string",
            "enum": ["studio_verified", "remote_verified", "self_submitted", "legacy_import"]
          },
          "model_version": {
            "type": "string",
            "description": "Version of the acoustic analysis model used for capture."
          }
        }
      }
    },
    "delegates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["delegate_id", "permissions", "authorized_at"],
        "properties": {
          "delegate_id": { "type": "string" },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["consent_grant", "consent_revoke", "royalty_view", "audit_view"]
            }
          },
          "authorized_at": { "type": "string", "format": "date-time" },
          "expires_at": { "type": ["string", "null"], "format": "date-time" }
        }
      },
      "description": "Authorized delegates who may act on behalf of the creator."
    },
    "heirs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heir_id", "relationship", "priority_order"],
        "properties": {
          "heir_id": { "type": "string" },
          "relationship": {
            "type": "string",
            "enum": ["spouse", "child", "sibling", "estate_trustee", "designated_beneficiary"]
          },
          "priority_order": { "type": "integer", "minimum": 1 },
          "legal_document_ref": { "type": ["string", "null"] }
        }
      },
      "description": "Heirs who inherit voice estate governance after creator's passing."
    },
    "linked_consents": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Array of NCP claim_scope_ids anchored to this voice estate."
    },
    "revocations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["revocation_id", "consent_scope_id", "effective_at", "reason"],
        "properties": {
          "revocation_id": { "type": "string", "format": "uuid" },
          "consent_scope_id": { "type": "string" },
          "effective_at": { "type": "string", "format": "date-time" },
          "enforced_at": { "type": ["string", "null"], "format": "date-time" },
          "reason": { "type": "string" }
        }
      }
    },
    "governance_rules": {
      "type": "object",
      "required": ["creator_primary_control", "delegate_control_enabled", "estate_transfer_enabled"],
      "properties": {
        "creator_primary_control": {
          "type": "boolean",
          "description": "Creator retains ultimate authority over all consent decisions."
        },
        "delegate_control_enabled": {
          "type": "boolean",
          "description": "Whether delegates may act on behalf of creator."
        },
        "estate_transfer_enabled": {
          "type": "boolean",
          "description": "Whether voice estate governance may transfer to heirs."
        },
        "consent_required_for_commercial": {
          "type": "boolean",
          "default": true,
          "description": "Explicit consent required for any commercial use."
        },
        "auto_renew_prohibited": {
          "type": "boolean",
          "default": false,
          "description": "If true, no consent records may use auto_renew."
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "examples": [
    {
      "voice_estate_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "creator_id": "RSP_001",
      "hvs_id": "HVS-RSP001-2026",
      "estate_status": "active",
      "sovereignty_status": "verified",
      "acoustic_fingerprint": "sha256:a9b8c7d6e5f4a3b2c1d0e9f8a7b6c5d4e3f2a1b0c9d8e7f6a5b4c3d2e1f0a9b8",
      "primary_voiceprints": [
        {
          "voiceprint_id": "vp-001-rsp",
          "hash": "sha256:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
          "captured_at": "2026-03-20T10:00:00Z",
          "capture_method": "studio_verified",
          "model_version": "Librosa-0.10.1"
        }
      ],
      "delegates": [],
      "heirs": [],
      "linked_consents": [],
      "revocations": [],
      "governance_rules": {
        "creator_primary_control": true,
        "delegate_control_enabled": false,
        "estate_transfer_enabled": true,
        "consent_required_for_commercial": true,
        "auto_renew_prohibited": false
      },
      "created_at": "2026-03-20T10:00:00Z",
      "updated_at": "2026-03-25T18:00:00Z"
    }
  ]
}
