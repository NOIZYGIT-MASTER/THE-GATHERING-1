{
  "name": "noizylab",
  "version": "18.0.0",
  "description": "NOIZY Empire \u2014 HEAVEN Consent Kernel + DreamChamber AI Platform",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "./scripts/deploy-heaven.sh",
    "deploy:force": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run",
    "deploy:canary": "./scripts/canary-deploy.sh",
    "deploy:gradual": "./scripts/gradual-rollout.sh",
    "doctor": "./scripts/wrangler-doctor.sh",
    "smoke": "./scripts/smoke-test.sh",
    "rollback": "./scripts/rollback.sh",
    "audit": "./scripts/export-audit-log.sh",
    "tail": "wrangler tail heaven",
    "seed": "wrangler d1 execute gabriel_db --remote --file=sql/seed.sql",
    "schema": "wrangler d1 execute gabriel_db --remote --file=sql/schema.sql",
    "health": "curl -s https://heaven.rsp-5f3.workers.dev/health | jq",
    "status": "./scripts/full-status.sh",
    "readiness": "bash scripts/deploy-readiness.sh",
    "readiness:quick": "bash scripts/deploy-readiness.sh --quick",
    "check:placeholders": "bash scripts/check-placeholders.sh",
    "test:gateway": "cd workers/consent-gateway && npm test",
    "test:router": "cd workers/cb01-router && npm test",
    "test:proxy": "cd workers/claude-proxy && npm test",
    "dc:dev": "cd dreamchamber && npm run dev",
    "dc:start": "cd dreamchamber && npm start",
    "deployments": "wrangler deployments list",
    "ethics": "./scripts/ethics-gate.sh",
    "canary:monitor": "./scripts/canary-monitor.sh",
    "budget": "node scripts/check-error-budget.js",
    "budget:mock": "node scripts/check-error-budget.js --mock",
    "flags:setup": "./scripts/setup-feature-flags.sh",
    "dr:quick": "./scripts/dr-drill.sh quick",
    "dr:full": "./scripts/dr-drill.sh full",
    "dr:tabletop": "./scripts/dr-drill.sh tabletop",
    "multi-region": "./scripts/multi-region-health.sh",
    "change-freeze": "./scripts/change-freeze.sh",
    "promote": "./scripts/promote-variant.sh",
    "postmortem": "./scripts/capture-postmortem.sh",
    "r2:create": "wrangler r2 bucket create noizy-voice-vault",
    "r2:list": "wrangler r2 bucket list",
    "kv:create:flags": "wrangler kv namespace create FEATURE_FLAGS",
    "kv:create:gap": "wrangler kv namespace create GAP_SOLVER",
    "upgrade:wrangler": "npm install -g wrangler@latest",
    "session:new": "node packages/session-proof/cli.mjs new --mode local",
    "session:seal": "node packages/session-proof/cli.mjs seal",
    "session:verify": "node packages/session-proof/cli.mjs verify",
    "session:export": "node packages/session-proof/cli.mjs export",
    "recall:index": "node packages/session-recall/cli.mjs index --all",
    "recall:search": "node packages/session-recall/cli.mjs search",
    "recall:stats": "node packages/session-recall/cli.mjs stats",
    "bridge:bootstrap": "bash apps/voice-bridge-http/scripts/bootstrap-gcp.sh",
    "bridge:deploy": "cd apps/voice-bridge-http && gcloud run deploy noizy-voice-bridge --source . --region us-central1 --project gen-lang-client-0531202734 --no-allow-unauthenticated",
    "bridge:logs": "gcloud run services logs read noizy-voice-bridge --region us-central1 --project gen-lang-client-0531202734 --limit 50"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "body-parser": "^2.2.2",
    "docx": "^9.6.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "wrangler": "^4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Robert Stephen Plowman (RSP_001)",
  "license": "UNLICENSED"
}
