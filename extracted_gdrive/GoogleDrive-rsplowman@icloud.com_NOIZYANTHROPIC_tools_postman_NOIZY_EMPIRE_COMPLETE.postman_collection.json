{
  "info": {
    "name": "NOIZY EMPIRE — Complete API Collection",
    "description": "Every endpoint across the NOIZY Empire.\niPhone → Postman → Webhooks → ALL services.\n\nGOD.local = 10.90.90.10\nHeaven edge = heaven.rsp-5f3.workers.dev\n\nRSP_001 | GORUNFREE | 2026",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "GOD", "value": "http://10.90.90.10" },
    { "key": "GOD_LOCAL", "value": "http://localhost" },
    { "key": "HEAVEN", "value": "https://heaven.rsp-5f3.workers.dev" },
    { "key": "NOIZY_API_KEY", "value": "{{NOIZY_API_KEY}}" },
    { "key": "VOICE_AUTH_TOKEN", "value": "{{VOICE_AUTH_TOKEN}}" },
    { "key": "NOIZYSTREAM_TOKEN", "value": "{{NOIZYSTREAM_TOKEN}}" }
  ],
  "item": [
    {
      "name": "01 — GABRIEL (:7777)",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{GOD}}:7777/health" }
        },
        {
          "name": "Speak (TTS)",
          "request": {
            "method": "POST", "url": "{{GOD}}:7777/speak",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"text\": \"Hello Rob. GABRIEL is online. GORUNFREE.\"}" }
          }
        },
        {
          "name": "Brief",
          "request": {
            "method": "POST", "url": "{{GOD}}:7777/brief",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"context\": \"iPhone morning briefing\"}" }
          }
        },
        {
          "name": "Command",
          "request": {
            "method": "POST", "url": "{{GOD}}:7777/command",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"command\": \"status\", \"args\": {}}" }
          }
        },
        {
          "name": "Get Memcell",
          "request": { "method": "GET", "url": "{{GOD}}:7777/memcell/noizy:gospel" }
        },
        {
          "name": "Set Memcell",
          "request": {
            "method": "POST", "url": "{{GOD}}:7777/memcell/iphone:ping",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"value\": {\"source\": \"iPhone 15 Pro Max\", \"ts\": \"{{$timestamp}}\"}}" }
          }
        },
        {
          "name": "Tasks List",
          "request": { "method": "GET", "url": "{{GOD}}:7777/tasks" }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST", "url": "{{GOD}}:7777/task",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"title\": \"iPhone task\", \"priority\": \"high\", \"assigned\": \"GABRIEL\"}" }
          }
        }
      ]
    },
    {
