  "script_lines": [
    {
      "line_number": 1,
      "text": "Every sound has a story. Listen close.",
      "direction": "Intimate, like sharing a secret with a student",
      "energy_band": "whisper"
    },
    {
      "line_number": 2,
      "text": "The silence between notes — that's where the music breathes.",
      "direction": "Reflective, let the pauses speak",
      "energy_band": "whisper"
    },
    {
      "line_number": 3,
      "text": "You don't find your voice. You remember it.",
      "direction": "Warm wisdom, like a teacher who believes in you",
      "energy_band": "whisper"
    },
    {
      "line_number": 4,
      "text": "Before you can make noise, you have to understand quiet.",
      "direction": "Gentle paradox, let it land slowly",
      "energy_band": "whisper"
    },
    {
      "line_number": 5,
      "text": "This is your sound. Nobody else's. Guard it.",
      "direction": "Protective, sovereign, paternal warmth",
      "energy_band": "whisper"
    }
  ],
