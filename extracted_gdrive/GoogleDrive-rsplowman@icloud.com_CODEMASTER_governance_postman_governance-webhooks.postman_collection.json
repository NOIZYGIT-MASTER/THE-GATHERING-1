        {
          "name": "GABRIEL — Write MemCell",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"value\": {\n    \"execution_id\": \"nf-2026-04-08-00001\",\n    \"event\": \"commit_validated\",\n    \"repo\": \"NOIZYANTHROPIC\",\n    \"ts\": \"2026-04-08T10:00:00Z\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:7777/memcell/governance:audit:test",
              "protocol": "http",
              "host": ["localhost"],
              "port": "7777",
              "path": ["memcell", "governance:audit:test"]
            },
            "description": "Write a governance event to GABRIEL MemCell storage."
          },
          "response": []
        }
      ]
    },
    {
      "name": "governance/contracts",
      "item": [
