              "port": "7777",
              "path": ["health"]
            },
            "description": "Verify GABRIEL daemon is alive. Expect uptime, version."
          },
          "response": []
        },
        {
          "name": "GABRIEL — Speak",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Governance audit: commit validated on NOIZYANTHROPIC main.\"\n}"
            },
            "url": {
              "raw": "http://localhost:7777/speak",
              "protocol": "http",
              "host": ["localhost"],
              "port": "7777",
              "path": ["speak"]
            },
            "description": "Trigger spoken alert via GABRIEL TTS."
