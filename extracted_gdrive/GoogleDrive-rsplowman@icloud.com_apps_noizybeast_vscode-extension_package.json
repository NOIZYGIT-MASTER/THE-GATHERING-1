  "version": "4.0.0",
  "publisher": "noizy-ai",
  "author": {
    "name": "Robert Stephen Plowman",
    "email": "rsp@noizy.ai"
  },
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.74.0"
  },
