    "configuration": {
      "title": "NOIZYBEAST",
      "properties": {
        "noizybeast.gabrielUrl": {
          "type": "string",
          "default": "http://localhost:9777",
          "description": "GABRIEL V4 DreamChamber URL (port 9777)"
        },
        "noizybeast.voiceBridgeUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Voice Bridge server URL"
        },
        "noizybeast.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama / Gemma3 URL"
        },
        "noizybeast.cfAccount": {
          "type": "string",
          "default": "5f36aa9795348ea681d0b21910dfc82a",
          "description": "Cloudflare Account ID"
        },
        "noizybeast.operator": {
          "type": "string",
          "default": "RSP_001",
          "description": "Operator ID for consent and audit logging"
        },
        "noizybeast.noizyLabPath": {
          "type": "string",
          "default": "~/NOIZYLAB",
          "description": "Path to NOIZYLAB directory"
        },
        "noizybeast.targetDate": {
          "type": "string",
          "default": "2026-04-17",
          "description": "Target delivery date (April 17)"
        },
        "noizybeast.autoFlowSync": {
          "type": "boolean",
          "default": true,
          "description": "Auto-run T2 Flow Sync when VS Code opens"
        },
        "noizybeast.autoCapture": {
          "type": "boolean",
          "default": false,
          "description": "Auto-run T10 Dream Capture on window close"
        },
        "noizybeast.heavenEdgeUrl": {
          "type": "string",
          "default": "https://heaven.rsp-5f3.workers.dev",
          "description": "Heaven edge worker URL (Cloudflare)"
        },
        "noizybeast.gabrielWssUrl": {
          "type": "string",
          "default": "wss://heaven.rsp-5f3.workers.dev/ws",
          "description": "Gabriel Edge WebSocket URL"
        }
      }
    },
    "snippets": [
      {
        "language": "typescript",
        "path": "./snippets/noizy-ts.json"
      },
      {
        "language": "javascript",
        "path": "./snippets/noizy-js.json"
      }
    ]
