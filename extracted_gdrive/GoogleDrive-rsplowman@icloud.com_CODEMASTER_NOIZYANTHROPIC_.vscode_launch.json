{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run acorn",
      "runtimeExecutable": "acorn",
      "cwd": "${workspaceFolder}",
      "args": []
    },
    {
      "name": "Heaven Worker (wrangler dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "wrangler",
        "dev"
      ],
      "cwd": "${workspaceFolder}/repos/noizy-heaven",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Supersonic MCP",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/mcp/supersonic/src/index.js",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "GABRIEL Daemon (port 9777)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/apps/GABRIEL/daemon/gabriel-daemon.js",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "env": {
        "GABRIEL_PORT": "9777"
      }
    },
    {
      "name": "DreamChamber (port 7777)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "start"
      ],
      "cwd": "${workspaceFolder}/apps/dreamchamber",
      "console": "integratedTerminal"
    },
    {
      "name": "Consent Gateway Worker",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "wrangler",
        "dev"
      ],
      "cwd": "${workspaceFolder}/workers/consent-gateway",
      "console": "integratedTerminal"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:NOIZYANTHROPIC}/swift-library/che-logic-pro-mcp",
      "name": "Debug CheLogicProMCP (swift-library/che-logic-pro-mcp)",
      "target": "CheLogicProMCP",
      "configuration": "debug",
      "preLaunchTask": "swift: Build Debug CheLogicProMCP (swift-library/che-logic-pro-mcp)"
    },
    {
      "type": "swift",
